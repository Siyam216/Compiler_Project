Grammar

    0 $accept: program $end

    1 program: statement_list

    2 statement_list: /* empty */
    3               | statement_list statement

    4 statement: var_decl optional_semi
    5          | assignment optional_semi
    6          | print_stmt optional_semi
    7          | input_stmt optional_semi
    8          | return_stmt optional_semi
    9          | if_stmt
   10          | while_stmt
   11          | loopin_stmt
   12          | block

   13 optional_semi: /* empty */
   14              | ';'
   15              | SYMBOL_SEMI

   16 block: '{' statement_list '}'

   17 var_decl: decl_kw IDENTIFIER
   18         | decl_kw IDENTIFIER '=' expr
   19         | decl_kw IDENTIFIER OPERATOR_ASSIGN expr

   20 decl_kw: KEYWORD_BET
   21        | KEYWORD_FR
   22        | TYPE_INTY
   23        | TYPE_STRINGY
   24        | TYPE_BOOLY
   25        | TYPE_FLOATY

   26 assignment: IDENTIFIER '=' expr
   27           | IDENTIFIER OPERATOR_ASSIGN expr

   28 if_stmt: KEYWORD_VIBECHECK '(' expr ')' block if_tail

   29 if_tail: /* empty */
   30        | KEYWORD_AINT '(' expr ')' block if_tail
   31        | KEYWORD_MEH block

   32 while_stmt: KEYWORD_VIBE '(' expr ')' block

   33 loopin_stmt: KEYWORD_LOOPIN for_init '#' expr '#' for_update block

   34 for_init: /* empty */
   35         | var_decl
   36         | assignment

   37 for_update: /* empty */
   38           | assignment
   39           | KEYWORD_GLOWUP IDENTIFIER
   40           | KEYWORD_FALLOFF IDENTIFIER

   41 print_stmt: KEYWORD_SPILL_TEA '(' expr ')'

   42 input_stmt: KEYWORD_CHECKIT '(' IDENTIFIER ')'

   43 return_stmt: KEYWORD_YEET
   44            | KEYWORD_YEET expr

   45 expr: expr OPERATOR_OR expr
   46     | expr OPERATOR_AND expr
   47     | expr OPERATOR_EQ expr
   48     | expr OPERATOR_NEQ expr
   49     | expr OPERATOR_LT expr
   50     | expr OPERATOR_LTE expr
   51     | expr OPERATOR_GT expr
   52     | expr OPERATOR_GTE expr
   53     | expr OPERATOR_PLUS expr
   54     | expr OPERATOR_MINUS expr
   55     | expr OPERATOR_MUL expr
   56     | expr OPERATOR_DIV expr
   57     | expr OPERATOR_MOD expr
   58     | expr KEYWORD_RATIO expr
   59     | OPERATOR_NOT expr
   60     | '(' expr ')'
   61     | literal
   62     | IDENTIFIER

   63 literal: INT_LITERAL
   64        | FLOAT_LITERAL
   65        | STRING_CONTENT
   66        | HEX_LITERAL
   67        | BIN_LITERAL
   68        | CHAR_LITERAL
   69        | CHAR_ESCAPE
   70        | KEYWORD_NOCAP
   71        | KEYWORD_CAP
   72        | VAL_TRUE
   73        | VAL_FALSE
   74        | KEYWORD_NPC


